+    private fun ensureEqualizer(): Equalizer? {
+        val exo = getExoPlayer()
+        val sessionId = exo?.audioSessionId ?: 0
+        
+        // If equalizer already exists for this session, return it
+        if (equalizer != null && currentSessionId == sessionId) {
+            return equalizer
+        }
+        
+        // Session ID changed or equalizer is null. Re-create.
+        try {
+            equalizer?.release()
+            equalizer = null
+            
+            // Note: If sessionId is 0 or ExoPlayer.AUDIO_SESSION_ID_UNSET, we fallback to session 0 (global)
+            val idToUse = if (sessionId > 0) sessionId else 0
+            equalizer = Equalizer(0, idToUse)
+            currentSessionId = sessionId
+            Timber.d("Equalizer initialized with audioSessionId $idToUse (requested $sessionId)")
+            
+            // Apply isEqEnabled state
+            equalizer?.enabled = isEqEnabled
+            
+            if (isEqEnabled) {
+                // Apply preset or custom levels
+                val eq = equalizer
+                if (eq != null) {
+                    if (currentPresetIndex >= 0) {
+                        try {
+                            eq.usePreset(currentPresetIndex)
+                            // Retrieve and update cache with preset levels
+                            val bands = eq.numberOfBands
+                            for (b in 0 until bands) {
+                                eqLevels[b.toShort()] = eq.getBandLevel(b.toShort())
+                            }
+                        } catch (e: Exception) {
+                            Timber.e("Failed to apply cached preset $currentPresetIndex: ${e.message}")
+                        }
+                    } else if (eqLevels.isNotEmpty()) {
+                        for ((band, level) in eqLevels) {
+                            try {
+                                eq.setBandLevel(band, level)
+                            } catch (e: Exception) {
+                                Timber.e("Failed to apply cached band $band level $level: ${e.message}")
+                            }
+                        }
+                    }
+                }
+            }
+            return equalizer
+        } catch (e: Exception) {
+            Timber.e("Equalizer init failed for session $sessionId: ${e.message}")
+            return null
+        }
